# Central Environment Configuration

# OAuth Configuration
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret
OIDC_USER_ENDPOINT=your_user_endpoint
OIDC_AUTHORIZE_URL=your_authorize_url
OIDC_JWK_URL=your_jwk_url
OIDC_ACCESS_TOKEN_URL=your_access_token_url
OIDC_REDIRECT_URL=http://172.22.0.27:5001/api/authorize

# Role Claims
OIDC_ADMIN_CLAIM=admins
OIDC_TEACHER_CLAIM=lehrende
OIDC_STUDENT_CLAIM=schuelerinnen
OIDC_OFFICE_CLAIM=sekretariat

# Database
SQLALCHEMY_DATABASE_URI=db/main.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Unify Configuration (if using Unify module)
UNIFY_BASE_URL=https://192.168.200.5:8443
UNIFY_USERNAME=api-user
UNIFY_PASSWORD=your_password
UNIFY_SITE=mdg1

# Development Settings
DEV_ALWAYS_LOGIN=False
TIMEDELTA=2
AP_MAX_TIME_DIFFERENCE=1440

# Backend Configuration
BACKEND_HOST=172.22.0.27
BACKEND_PORT=5001

# Frontend Configuration
FRONTEND_HOST=172.22.0.27
FRONTEND_PORT=3000

# Legacy Support (use BACKEND_* values above instead)
HOST_NAME=172.22.0.27
HOST_PORT=5001

# Application Settings
DEBUG=True
USE_RELOADER=True
PRODUCTION=False  # Set to True in production (enables HTTPS, secure cookies)
APP_SECRET_KEY=your_secret_key_here_generate_a_random_string
SESSION_COOKIE_DOMAIN="172.22.0.27"

# Document Extraction Services (docker-compose.dev.yml)
DOCLING_URL=http://localhost:5002
TIKA_URL=http://localhost:9998
